{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/js",
      "destination": "https://guilds-dev-js.vercel.app"
    },
    {
      "source": "/js/:path*",
      "destination": "https://guilds-dev-js.vercel.app/:path*"
    },
    {
      "source": "/cyber",
      "destination": "https://guilds-dev-cyber.vercel.app/cyber"
    },
    {
      "source": "/cyber/:path*",
      "destination": "https://guilds-dev-cyber.vercel.app/cyber/:path*"
    },
    {
      "source": "/ai",
      "destination": "https://guilds-dev-ai.vercel.app"
    },
    {
      "source": "/ai/:path*",
      "destination": "https://guilds-dev-ai.vercel.app/:path*"
    }
  ]
}